# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Claude API (for judgement analysis — bot works without it but better with)
ANTHROPIC_API_KEY=your_anthropic_api_key

# The Racing API (https://theracingapi.com) — required for data
RACING_API_USERNAME=your_racing_api_username
RACING_API_PASSWORD=your_racing_api_password

# Bot Settings
TIMEZONE=Europe/London
SCRAPE_TIME=07:00
ANALYSIS_TIME=08:00
RESULTS_TIME=18:00
AUTO_SCHEDULE=false

# Logging
LOG_LEVEL=INFO
